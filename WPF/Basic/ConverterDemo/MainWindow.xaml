<Window
    x:Class="ConverterDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ConverterDemo"
    mc:Ignorable="d"
    Title="MainWindow"
    Height="450"
    Width="800">

    <Window.Resources>
        <local:ITestConverter
            x:Key="TestConverter" />
        <local:ITestMultiValueConverter
            x:Key="TestMultiValueConverter" />
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <StackPanel>
            <TextBlock
                Text="0"
                Name="tb1"
                FontSize="50" />
            <TextBlock
                Text="{Binding Path=Text,ElementName=tb1,Converter={StaticResource TestConverter}}"
                FontSize="50" />
            <TextBlock
                Text="1"
                Name="tb2"
                FontSize="50" />
            <TextBlock
                Text="{Binding Path=Text,ElementName=tb2,Converter={StaticResource TestConverter}}"
                FontSize="50" />
        </StackPanel>

        <StackPanel
            Grid.Column="1">
            <Slider
                x:Name="SliderR"
                Minimum="0"
                Maximum="255"
                Width="300"
                Margin="10" />
            <Slider
                x:Name="SliderG"
                Minimum="0"
                Maximum="255"
                Width="300"
                Margin="10" />
            <Slider
                x:Name="SliderB"
                Minimum="0"
                Maximum="255"
                Width="300"
                Margin="10" />

            <Path
                HorizontalAlignment="Center">
                <Path.Data>
                    <EllipseGeometry
                        Center="100,150"
                        RadiusX="100"
                        RadiusY="100" />
                </Path.Data>
                <Path.Fill>
                    <MultiBinding
                        Converter="{StaticResource TestMultiValueConverter}">
                        <Binding
                            ElementName="SliderR"
                            Path="Value" />
                        <Binding
                            ElementName="SliderG"
                            Path="Value" />
                        <Binding
                            ElementName="SliderB"
                            Path="Value" />
                    </MultiBinding>
                </Path.Fill>
            </Path>
        </StackPanel>

    </Grid>

</Window>
